{
    "name": "moffhub/cli",
    "description": "Moffhub Payment Standard CLI - scaffold, validate, and certify MPS connectors",
    "type": "project",
    "license": "MIT",
    "keywords": ["payments", "mps", "moffhub", "cli", "connector", "certification"],
    "homepage": "https://github.com/Moffhub-Solutions/cli",
    "support": {
        "issues": "https://github.com/Moffhub-Solutions/cli/issues",
        "source": "https://github.com/Moffhub-Solutions/cli"
    },
    "authors": [
        { "name": "Moffhub", "homepage": "https://moffhub.com" }
    ],
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.0",
        "moffhub/mps-spec": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "Moffhub\\Cli\\": "src/"
        }
    },
    "bin": ["bin/moffhub"],
    "minimum-stability": "stable",
    "prefer-stable": true
}
